// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  VENDOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONFIRMED
  REJECTED
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String?
  role           Role          @default(VENDOR)
  accountStatus  AccountStatus @default(ACTIVE)
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  vendorProfile  VendorProfile?
  inquiries      EventInquiry[]
  activityLogs   ActivityLog[]
  manualEvents   ManualEvent[]
  sessions       Session[]
  accounts       Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Vendor Models ────────────────────────────────────────────────────────────

model VendorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  vendorName  String
  category    String
  location    String
  phone       String?
  description String?  @db.Text
  imageUrl    String?
  rating      Float?   @default(4.5)
  totalEvents Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventInquiry {
  id            String        @id @default(cuid())
  vendorId      String
  clientName    String
  clientEmail   String
  clientPhone   String?
  eventType     String
  eventDate     DateTime
  eventLocation String
  guestCount    Int
  budget        Float
  message       String?       @db.Text
  status        InquiryStatus @default(NEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  vendor        User          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

// ─── Manual Calendar Events ───────────────────────────────────────────────────

model ManualEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  eventDate   DateTime
  endDate     DateTime?
  location    String?
  color       String   @default("purple")  // purple | rose | sky | amber
  allDay      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  vendorId    String
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  vendor      User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}
